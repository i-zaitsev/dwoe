# squid.conf - Filtering proxy for isolated agent container
# Only allowlisted domains are accessible

# Basic settings
http_port {{.ProxyPort}}
cache deny all
cache_log /dev/null

# DNS settings
dns_nameservers 8.8.8.8 8.8.4.4

# Allowlisted domains - loaded from external file
acl allowlist dstdomain "/etc/squid/allowlist.txt"

# Block all SSL bumping - just tunnel HTTPS
acl SSL_ports port 443
acl CONNECT method CONNECT

# Allow CONNECT only to allowlisted domains on SSL ports
http_access allow CONNECT SSL_ports allowlist

# Allow HTTP to allowlisted domains
http_access allow allowlist

# Deny everything else
deny_info ERR_ACCESS_DENIED all
http_access deny all

# Performance tuning
maximum_object_size 100 MB
cache_mem 256 MB

# Timeouts
connect_timeout 30 seconds
read_timeout 60 seconds
request_timeout 60 seconds

# Logging
logformat custom %>a %ui %un [%tl] "%rm %ru HTTP/%rv" %>Hs %<st "%{Referer}>h" "%{User-Agent}>h" %Ss:%Sh
access_log stdio:/var/log/squid/access.log custom

# Shutdown settings
shutdown_lifetime 3 seconds
