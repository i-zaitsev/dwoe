FROM alpine:latest
RUN apk add --no-cache git
RUN printf '#!/bin/sh\n\
cd /workspace\n\
git config --global user.name "Test Agent"\n\
git config --global user.email "agent@test.dev"\n\
git config --global init.defaultBranch main\n\
if [ ! -d ".git" ]; then\n\
  git init\n\
  git add .\n\
  git commit -m "Initial commit" --allow-empty\n\
fi\n\
echo "package feature" > feature.go\n\
git add .\n\
git commit -m "Add feature"\n\
echo "package feature_test" > feature_test.go\n\
git add .\n\
git commit -m "Add tests"\n\
echo "test ok"\n\
echo "<promise>DONE</promise>"\n' > /test-entry.sh && chmod +x /test-entry.sh
ENTRYPOINT ["/test-entry.sh"]
WORKDIR /workspace
